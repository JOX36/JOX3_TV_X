<?xml version="1.0" encoding="utf-8"?>
<!--
    Home en horizontal (Opción 3, elegida por JOX3): en vez de solo
    reacomodar el mismo diseño vertical, se aprovecha el ancho extra con
    un panel FIJO a la izquierda (banner + mini-reproductor de canal en
    vivo + accesos rápidos) que nunca se mueve, y a la derecha una columna
    con scroll propio que trae TODO el catálogo (Seguir viendo, Favoritos,
    Descubre, Destacados...). El panel izquierdo se queda visible incluso
    mientras se busca — solo la columna derecha cambia entre catálogo y
    resultados de búsqueda.

    Reutiliza EXACTAMENTE los mismos colores, degradados y drawables que
    ya existen para vertical (bg_banner_glow, bg_card_rounded, degradado
    de marca cian->azul->morado en el logo, etc.) — nada de esto es nuevo,
    solo se reorganiza el espacio.

    Comparte 3 bloques con el layout vertical vía <include> para que
    nunca se desincronicen: home_top_chrome (header/carga/vacío),
    home_content_rows (las filas de catálogo) y home_drawer (panel
    lateral). Todos los IDs coinciden con activity_home.xml para que
    HomeActivity.java funcione sin ningún cambio de código.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:orientation="vertical">

        <include layout="@layout/home_top_chrome" />

        <LinearLayout
            android:id="@+id/scroll_content"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:saveEnabled="false"
            android:orientation="horizontal">

            <!-- ============ PANEL IZQUIERDO: fijo, siempre visible ============ -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="38"
                android:orientation="vertical"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:paddingStart="18dp"
                android:paddingEnd="10dp"
                android:paddingBottom="14dp">

                <!-- Banner: mismo glow + carrusel que en vertical, ahora
                     apilado arriba del mini-reproductor (la columna es
                     angosta, no alcanza para ponerlos lado a lado y que
                     ambos se vean bien). -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="3"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <View
                        android:id="@+id/banner_glow"
                        android:layout_width="130dp"
                        android:layout_height="130dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_banner_glow" />

                    <androidx.viewpager2.widget.ViewPager2
                        android:id="@+id/hero_pager"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                </FrameLayout>

                <LinearLayout
                    android:id="@+id/hero_dots"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="8dp"
                    android:orientation="horizontal"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:clickable="false"
                    android:focusable="true"
                    android:stateListAnimator="@animator/focus_scale_row" />

                <!-- Mini-reproductor de canal en vivo: en horizontal
                     siempre visible (HomeActivity ya lo muestra en
                     cualquier orientación que no sea portrait — misma
                     lógica de siempre, sin tocar el código). -->
                <FrameLayout
                    android:id="@+id/mini_player_container"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="2"
                    android:background="@drawable/bg_card_rounded"
                    android:clipToOutline="true"
                    android:clickable="true"
                    android:focusable="false">

                    <androidx.media3.ui.PlayerView
                        android:id="@+id/mini_player_view"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:surface_type="texture_view"
                        app:use_controller="false" />

                    <TextView
                        android:id="@+id/mini_live_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|start"
                        android:layout_margin="8dp"
                        android:background="@drawable/bg_badge_live"
                        android:paddingStart="7dp"
                        android:paddingEnd="7dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:text="EN VIVO"
                        android:textColor="@color/text_primary"
                        android:textSize="9sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/btn_mini_expand"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:layout_gravity="top|end"
                        android:layout_margin="8dp"
                        android:background="#88000000"
                        android:padding="6dp"
                        android:src="@drawable/ic_expand"
                        android:clickable="true"
                        android:focusable="true"
                        android:stateListAnimator="@animator/focus_scale_button" />

                    <ImageView
                        android:id="@+id/btn_mini_mute"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="8dp"
                        android:background="#88000000"
                        android:padding="6dp"
                        android:src="@drawable/ic_mute"
                        android:clickable="true"
                        android:focusable="true"
                        android:stateListAnimator="@animator/focus_scale_button" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:background="#CC000000"
                        android:orientation="vertical"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="20dp"
                        android:paddingBottom="8dp">

                        <TextView
                            android:id="@+id/mini_channel_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <TextView
                            android:id="@+id/mini_epg_now"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="@color/accent_warm"
                            android:textSize="10sp"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:visibility="gone" />

                        <LinearLayout
                            android:id="@+id/mini_epg_progress_track"
                            android:layout_width="match_parent"
                            android:layout_height="3dp"
                            android:layout_marginTop="4dp"
                            android:background="#40000000"
                            android:orientation="horizontal"
                            android:visibility="gone">

                            <View
                                android:id="@+id/mini_epg_progress_fill"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="0"
                                android:background="@color/accent_purple" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="100"
                                android:background="@android:color/transparent" />
                        </LinearLayout>
                    </LinearLayout>
                </FrameLayout>

            </LinearLayout>

            <!-- Separador sutil entre el panel fijo y el catálogo. -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#22222E" />

            <!-- ============ PANEL DERECHO: catálogo, con su propio scroll ============ -->
            <ScrollView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="62">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/home_default_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingTop="16dp"
                        android:paddingBottom="24dp">

                        <!-- Chips de acceso rápido: en horizontal viven
                             aquí arriba del catálogo (son navegación, no
                             parte del banner) en vez de apretados dentro
                             del panel angosto de la izquierda. Mismo
                             estilo y colores de siempre. -->
                        <HorizontalScrollView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:scrollbars="none"
                            android:clipToPadding="false"
                            android:paddingStart="18dp"
                            android:paddingEnd="8dp"
                            android:layout_marginBottom="18dp">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/chip_favorites"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginEnd="10dp"
                                    android:background="@drawable/bg_chip_active"
                                    android:paddingStart="16dp"
                                    android:paddingEnd="16dp"
                                    android:paddingTop="9dp"
                                    android:paddingBottom="9dp"
                                    android:text="🔥  Favoritos"
                                    android:textColor="@color/text_primary"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:clickable="true"
                                    android:focusable="true"
                                    android:stateListAnimator="@animator/focus_scale_button" />

                                <TextView
                                    android:id="@+id/chip_live"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginEnd="10dp"
                                    android:background="@drawable/bg_pill_outline_accent"
                                    android:paddingStart="16dp"
                                    android:paddingEnd="16dp"
                                    android:paddingTop="9dp"
                                    android:paddingBottom="9dp"
                                    android:text="📡  TV en vivo"
                                    android:textColor="@color/accent"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:clickable="true"
                                    android:focusable="true"
                                    android:stateListAnimator="@animator/focus_scale_button" />

                                <TextView
                                    android:id="@+id/chip_movies"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginEnd="10dp"
                                    android:background="@drawable/bg_pill_outline_accent"
                                    android:paddingStart="16dp"
                                    android:paddingEnd="16dp"
                                    android:paddingTop="9dp"
                                    android:paddingBottom="9dp"
                                    android:text="🎬  Películas"
                                    android:textColor="@color/accent"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:clickable="true"
                                    android:focusable="true"
                                    android:stateListAnimator="@animator/focus_scale_button" />

                                <TextView
                                    android:id="@+id/chip_series"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/bg_pill_outline_accent"
                                    android:paddingStart="16dp"
                                    android:paddingEnd="16dp"
                                    android:paddingTop="9dp"
                                    android:paddingBottom="9dp"
                                    android:text="📺  Series"
                                    android:textColor="@color/accent"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:clickable="true"
                                    android:focusable="true"
                                    android:stateListAnimator="@animator/focus_scale_button" />
                            </LinearLayout>
                        </HorizontalScrollView>

                        <include layout="@layout/home_content_rows" />
                    </LinearLayout>

                    <!-- Resultados de búsqueda global: reemplaza al
                         catálogo en esta misma columna derecha. El panel
                         izquierdo (banner + canal en vivo) se queda
                         visible incluso buscando — mejora respecto a
                         vertical, donde todo se oculta durante la
                         búsqueda. -->
                    <LinearLayout
                        android:id="@+id/global_search_results"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        android:paddingTop="6dp"
                        android:paddingBottom="24dp"
                        android:visibility="gone" />

                </LinearLayout>
            </ScrollView>

        </LinearLayout>
    </LinearLayout>

    <include layout="@layout/home_drawer" />
</FrameLayout>
