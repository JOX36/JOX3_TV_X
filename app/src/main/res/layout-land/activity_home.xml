<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- ======================= CONTENIDO PRINCIPAL ======================= -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:orientation="vertical">

        <include layout="@layout/home_top_chrome" />

        <!-- Contenido principal -->
        <ScrollView
            android:id="@+id/scroll_content"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            <LinearLayout
                android:id="@+id/home_default_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="24dp">

                <!-- Banner: en móvil ocupa todo el ancho, solo imagen (sin
                     sinopsis ni botones, eso ahora vive en la pantalla de
                     detalle al tocar la card). El mini-reproductor de canal
                     en vivo que antes iba al lado solo se muestra en TV box
                     (HomeActivity lo oculta en móvil con isTv == false). -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:layout_marginStart="18dp"
                    android:layout_marginEnd="18dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp">

                    <!-- Columna del carrusel. weight=4 por defecto: si el
                         mini-reproductor de al lado queda GONE (móvil),
                         esta columna pasa a ocupar el 100% del ancho
                         automáticamente (así funciona layout_weight en
                         LinearLayout cuando el otro hijo está GONE). -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="4"
                        android:layout_marginEnd="10dp"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        android:orientation="vertical">

                        <!-- "glow_wrap" agrega el resplandor de fondo detrás
                             del banner: el View de glow va PRIMERO (en
                             Android, el primer hijo de un FrameLayout queda
                             atrás de los siguientes), centrado y más grande
                             que el propio banner para que sobresalga un
                             poco por los bordes. -->
                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="260dp"
                            android:clipChildren="false"
                            android:clipToPadding="false">

                            <View
                                android:id="@+id/banner_glow"
                                android:layout_width="160dp"
                                android:layout_height="160dp"
                                android:layout_gravity="center"
                                android:background="@drawable/bg_banner_glow" />

                            <androidx.viewpager2.widget.ViewPager2
                                android:id="@+id/hero_pager"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent" />
                        </FrameLayout>

                        <!-- Indicador de posición del banner. Con control
                             remoto, este mismo indicador recibe el foco y
                             las flechas izquierda/derecha cambian la card
                             del banner (ver HomeActivity.setupHeroPager). -->
                        <LinearLayout
                            android:id="@+id/hero_dots"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="10dp"
                            android:orientation="horizontal"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:clickable="false"
                            android:focusable="true"
                            android:stateListAnimator="@animator/focus_scale_row" />
                    </LinearLayout>

                    <!-- Mini-reproductor de canal en vivo: SOLO TV box.
                         HomeActivity le pone visibility=GONE en móvil. -->
                    <FrameLayout
                        android:id="@+id/mini_player_container"
                        android:layout_width="0dp"
                        android:layout_height="260dp"
                        android:layout_weight="3"
                        android:background="@drawable/bg_card_rounded"
                        android:clipToOutline="true"
                        android:clickable="true"
                        android:focusable="false">

                        <androidx.media3.ui.PlayerView
                            android:id="@+id/mini_player_view"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            app:surface_type="texture_view"
                            app:use_controller="false" />

                        <TextView
                            android:id="@+id/mini_live_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="top|start"
                            android:layout_margin="8dp"
                            android:background="@drawable/bg_badge_live"
                            android:paddingStart="7dp"
                            android:paddingEnd="7dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp"
                            android:text="EN VIVO"
                            android:textColor="@color/text_primary"
                            android:textSize="9sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/btn_mini_expand"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="8dp"
                            android:background="#88000000"
                            android:padding="6dp"
                            android:src="@drawable/ic_expand"
                            android:clickable="true"
                            android:focusable="true"
                            android:stateListAnimator="@animator/focus_scale_button" />

                        <ImageView
                            android:id="@+id/btn_mini_mute"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_gravity="bottom|end"
                            android:layout_margin="8dp"
                            android:background="#88000000"
                            android:padding="6dp"
                            android:src="@drawable/ic_mute"
                            android:clickable="true"
                            android:focusable="true"
                            android:stateListAnimator="@animator/focus_scale_button" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:background="#CC000000"
                            android:orientation="vertical"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="20dp"
                            android:paddingBottom="8dp">

                            <TextView
                                android:id="@+id/mini_channel_name"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_primary"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:maxLines="1"
                                android:ellipsize="end" />

                            <TextView
                                android:id="@+id/mini_epg_now"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textColor="@color/accent_warm"
                                android:textSize="10sp"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:visibility="gone" />

                            <LinearLayout
                                android:id="@+id/mini_epg_progress_track"
                                android:layout_width="match_parent"
                                android:layout_height="3dp"
                                android:layout_marginTop="4dp"
                                android:background="#40000000"
                                android:orientation="horizontal"
                                android:visibility="gone">

                                <View
                                    android:id="@+id/mini_epg_progress_fill"
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="0"
                                    android:background="@color/accent_purple" />

                                <View
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="100"
                                    android:background="@android:color/transparent" />
                            </LinearLayout>
                        </LinearLayout>
                    </FrameLayout>
                </LinearLayout>

                <!-- Chips de navegación rápida: reemplazan los 3 botones
                     grandes que había antes. Llevan directo a cada sección
                     (ya no hay filas de TV en vivo/Películas/Series en el
                     Home). El primero ("Favoritos") usa el degradado de
                     marca como acento; los demás usan el mismo contorno de
                     color que ya se ve en otras partes de la app. -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:clipToPadding="false"
                    android:paddingStart="18dp"
                    android:paddingEnd="8dp"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/chip_favorites"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/bg_chip_active"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="9dp"
                            android:paddingBottom="9dp"
                            android:text="🔥  Favoritos"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true"
                            android:stateListAnimator="@animator/focus_scale_button" />

                        <TextView
                            android:id="@+id/chip_live"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/bg_pill_outline_accent"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="9dp"
                            android:paddingBottom="9dp"
                            android:text="📡  TV en vivo"
                            android:textColor="@color/accent"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true"
                            android:stateListAnimator="@animator/focus_scale_button" />

                        <TextView
                            android:id="@+id/chip_movies"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/bg_pill_outline_accent"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="9dp"
                            android:paddingBottom="9dp"
                            android:text="🎬  Películas"
                            android:textColor="@color/accent"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true"
                            android:stateListAnimator="@animator/focus_scale_button" />

                        <TextView
                            android:id="@+id/chip_series"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/bg_pill_outline_accent"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="9dp"
                            android:paddingBottom="9dp"
                            android:text="📺  Series"
                            android:textColor="@color/accent"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true"
                            android:stateListAnimator="@animator/focus_scale_button" />
                    </LinearLayout>
                </HorizontalScrollView>

                <include layout="@layout/home_content_rows" />

            </LinearLayout>

            <!-- Resultados de búsqueda global: agrupados por cuenta (la
                 activa primero, luego las alternas que tengan
                 coincidencias). Solo visible mientras hay texto en el
                 buscador; HomeActivity construye una fila por cuenta
                 dinámicamente, igual que las secciones de
                 ContentListActivity. -->
            <LinearLayout
                android:id="@+id/global_search_results"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:paddingTop="6dp"
                android:paddingBottom="24dp"
                android:visibility="gone" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <include layout="@layout/home_drawer" />
</FrameLayout>
