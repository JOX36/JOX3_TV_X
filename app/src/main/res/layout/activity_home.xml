<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <!-- Barra superior: logo, pestañas centradas, buscar + ajustes -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="18dp"
        android:paddingEnd="40dp"
        android:paddingTop="18dp"
        android:paddingBottom="18dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="JOX3 TV"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Pestañas centradas: ocupan el espacio flexible del medio -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/tab_home"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="26dp"
                android:text="Inicio"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tab_channels"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="26dp"
                android:text="Canales"
                android:textColor="@color/text_secondary"
                android:textSize="16sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tab_movies"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="26dp"
                android:text="Películas"
                android:textColor="@color/text_secondary"
                android:textSize="16sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tab_series"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="26dp"
                android:text="Series"
                android:textColor="@color/text_secondary"
                android:textSize="16sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tab_favorites"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="18dp"
                android:text="Favoritos"
                android:textColor="@color/text_secondary"
                android:textSize="16sp"
                android:clickable="true"
                android:focusable="true" />

            <ImageView
                android:id="@+id/btn_search_toggle"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_chip_inactive"
                android:padding="8dp"
                android:src="@drawable/ic_search"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <ImageView
            android:id="@+id/btn_settings"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginStart="14dp"
            android:background="@drawable/bg_chip_inactive"
            android:padding="8dp"
            android:src="@drawable/ic_settings"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Barra de búsqueda expandible, oculta por defecto -->
    <LinearLayout
        android:id="@+id/search_bar_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="14dp"
        android:visibility="gone">

        <EditText
            android:id="@+id/input_search"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_chip_inactive"
            android:drawableStart="@drawable/ic_search"
            android:drawablePadding="10dp"
            android:hint="Buscar canales, películas o series..."
            android:textColorHint="@color/text_secondary"
            android:textColor="@color/text_primary"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="14sp"
            android:singleLine="true"
            android:imeOptions="actionSearch" />
    </LinearLayout>

    <!-- Estado vacío (sin lista cargada) -->
    <LinearLayout
        android:id="@+id/layout_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Todavía no tienes una lista cargada"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/btn_go_settings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_chip_active"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="Ir a Ajustes"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Contenido principal -->
    <ScrollView
        android:id="@+id/scroll_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Banner destacado (4/7) + Mini-reproductor de canal en vivo (3/7) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="18dp"
                android:layout_marginEnd="18dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="14dp">

                <!-- Columna del carrusel (peso 4) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="4"
                    android:layout_marginEnd="10dp"
                    android:orientation="vertical">

                    <androidx.viewpager2.widget.ViewPager2
                        android:id="@+id/hero_pager"
                        android:layout_width="match_parent"
                        android:layout_height="310dp" />

                    <LinearLayout
                        android:id="@+id/hero_dots"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal" />
                </LinearLayout>

                <!-- Mini-reproductor de canal en vivo (peso 3) -->
                <FrameLayout
                    android:id="@+id/mini_player_container"
                    android:layout_width="0dp"
                    android:layout_height="310dp"
                    android:layout_weight="3"
                    android:background="@drawable/bg_card_rounded"
                    android:clipToOutline="true"
                    android:clickable="true"
                    android:focusable="true">

                    <androidx.media3.ui.PlayerView
                        android:id="@+id/mini_player_view"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:surface_type="texture_view"
                        app:use_controller="false" />

                    <TextView
                        android:id="@+id/mini_live_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|start"
                        android:layout_margin="8dp"
                        android:background="@drawable/bg_badge_live"
                        android:paddingStart="7dp"
                        android:paddingEnd="7dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:text="EN VIVO"
                        android:textColor="@color/text_primary"
                        android:textSize="9sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/btn_mini_expand"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_gravity="top|end"
                        android:layout_margin="8dp"
                        android:background="#88000000"
                        android:padding="6dp"
                        android:src="@drawable/ic_expand" />

                    <ImageView
                        android:id="@+id/btn_mini_mute"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="8dp"
                        android:background="#88000000"
                        android:padding="6dp"
                        android:src="@drawable/ic_mute" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:background="#CC000000"
                        android:orientation="vertical"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="20dp"
                        android:paddingBottom="8dp">

                        <TextView
                            android:id="@+id/mini_channel_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <TextView
                            android:id="@+id/mini_epg_now"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="@color/accent_warm"
                            android:textSize="10sp"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:visibility="gone" />
                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>

            <!-- Continuar viendo -->
            <LinearLayout
                android:id="@+id/row_continue_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:layout_marginBottom="10dp"
                    android:text="Continuar viendo"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/row_continue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:clipToPadding="false"
                    android:layout_marginBottom="22dp" />
            </LinearLayout>

            <!-- Favoritos -->
            <LinearLayout
                android:id="@+id/row_favorites_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:layout_marginBottom="10dp"
                    android:text="★ Favoritos"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/row_favorites"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:clipToPadding="false"
                    android:layout_marginBottom="22dp" />
            </LinearLayout>

            <!-- Categorías de canales en vivo -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Canales en vivo"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_see_all_live"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ver todo ›"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/row_categories"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:clipToPadding="false"
                android:layout_marginBottom="12dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/row_live"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:clipToPadding="false" />

            <!-- Películas -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:layout_marginTop="26dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Películas"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_see_all_movies"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ver todo ›"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/row_movies"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:clipToPadding="false" />

            <!-- Series -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:layout_marginTop="26dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Series"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_see_all_series"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ver todo ›"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/row_series"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:clipToPadding="false" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
