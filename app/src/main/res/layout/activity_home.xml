<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- ======================= CONTENIDO PRINCIPAL ======================= -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:orientation="vertical">

        <!-- Barra superior: hamburguesa + logo. Las pestañas Inicio/Canales/
             Películas/Series que estaban aquí se quitaron: ahora viven en
             el panel lateral (drawer) y como accesos rápidos al fondo del
             Home. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="18dp"
            android:paddingBottom="14dp">

            <ImageView
                android:id="@+id/btn_open_drawer"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_chip_inactive"
                android:padding="10dp"
                android:src="@drawable/ic_menu"
                android:clickable="true"
                android:focusable="true"
                android:stateListAnimator="@animator/focus_scale_button"
                android:layout_marginEnd="12dp" />

            <!-- Logo en 3 tramos de color para imitar el degradado
                 cian -> azul -> morado (un TextView solo no puede pintar
                 un degradado real en el texto sin un shader personalizado,
                 así que se simula con 3 colores planos consecutivos). -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="J"
                    android:textColor="@color/accent"
                    android:textSize="22sp"
                    android:textStyle="bold|italic" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OX3"
                    android:textColor="#2979FF"
                    android:textSize="22sp"
                    android:textStyle="bold|italic" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" TV"
                    android:textColor="@color/accent_purple"
                    android:textSize="22sp"
                    android:textStyle="bold|italic" />
            </LinearLayout>

            <!-- Acceso directo a Ajustes sin tener que abrir el panel
                 lateral. "Ajustes" sigue existiendo también dentro del
                 drawer; este es solo un atajo rápido. -->
            <ImageView
                android:id="@+id/btn_settings"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_chip_inactive"
                android:padding="9dp"
                android:src="@drawable/ic_settings"
                android:tint="@color/accent"
                android:clickable="true"
                android:focusable="true"
                android:stateListAnimator="@animator/focus_scale_button" />
        </LinearLayout>

        <!-- Estado de cuenta: muy discreto a propósito (texto chico, color
             secundario, sin caja ni fondo) — solo un dato de referencia
             rápida, no debe competir visualmente con el resto del Home. -->
        <TextView
            android:id="@+id/account_status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingBottom="10dp"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:visibility="gone" />

        <!-- Barra de búsqueda expandible, oculta por defecto (se abre desde
             "Buscar" en el panel lateral) -->
        <LinearLayout
            android:id="@+id/search_bar_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingBottom="14dp"
            android:visibility="gone">

            <EditText
                android:id="@+id/input_search"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_chip_inactive"
                android:drawableStart="@drawable/ic_search"
                android:drawablePadding="10dp"
                android:hint="Buscar en vistos recientes o favoritos..."
                android:textColorHint="@color/text_secondary"
                android:textColor="@color/text_primary"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textSize="14sp"
                android:singleLine="true"
                android:imeOptions="actionSearch" />
        </LinearLayout>

        <!-- Estado vacío (sin lista cargada) -->
        <LinearLayout
            android:id="@+id/layout_empty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Todavía no tienes una lista cargada"
                android:textColor="@color/text_secondary"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/btn_go_settings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_chip_active"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:text="Ir a Ajustes"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Contenido principal -->
        <ScrollView
            android:id="@+id/scroll_content"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="24dp">

                <!-- Banner: en móvil ocupa todo el ancho, solo imagen (sin
                     sinopsis ni botones, eso ahora vive en la pantalla de
                     detalle al tocar la card). El mini-reproductor de canal
                     en vivo que antes iba al lado solo se muestra en TV box
                     (HomeActivity lo oculta en móvil con isTv == false). -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginStart="18dp"
                    android:layout_marginEnd="18dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp">

                    <!-- Columna del carrusel. weight=4 por defecto: si el
                         mini-reproductor de al lado queda GONE (móvil),
                         esta columna pasa a ocupar el 100% del ancho
                         automáticamente (así funciona layout_weight en
                         LinearLayout cuando el otro hijo está GONE). -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="4"
                        android:layout_marginEnd="10dp"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="260dp">

                            <androidx.viewpager2.widget.ViewPager2
                                android:id="@+id/hero_pager"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent" />
                        </FrameLayout>

                        <!-- Indicador de posición del banner. Con control
                             remoto, este mismo indicador recibe el foco y
                             las flechas izquierda/derecha cambian la card
                             del banner (ver HomeActivity.setupHeroPager). -->
                        <LinearLayout
                            android:id="@+id/hero_dots"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="10dp"
                            android:orientation="horizontal"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:clickable="false"
                            android:focusable="true"
                            android:stateListAnimator="@animator/focus_scale_row" />
                    </LinearLayout>

                    <!-- Mini-reproductor de canal en vivo: SOLO TV box.
                         HomeActivity le pone visibility=GONE en móvil. -->
                    <FrameLayout
                        android:id="@+id/mini_player_container"
                        android:layout_width="0dp"
                        android:layout_height="260dp"
                        android:layout_weight="3"
                        android:background="@drawable/bg_card_rounded"
                        android:clipToOutline="true"
                        android:clickable="true"
                        android:focusable="false">

                        <androidx.media3.ui.PlayerView
                            android:id="@+id/mini_player_view"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            app:surface_type="texture_view"
                            app:use_controller="false" />

                        <TextView
                            android:id="@+id/mini_live_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="top|start"
                            android:layout_margin="8dp"
                            android:background="@drawable/bg_badge_live"
                            android:paddingStart="7dp"
                            android:paddingEnd="7dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp"
                            android:text="EN VIVO"
                            android:textColor="@color/text_primary"
                            android:textSize="9sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/btn_mini_expand"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="8dp"
                            android:background="#88000000"
                            android:padding="6dp"
                            android:src="@drawable/ic_expand"
                            android:clickable="true"
                            android:focusable="true"
                            android:stateListAnimator="@animator/focus_scale_button" />

                        <ImageView
                            android:id="@+id/btn_mini_mute"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_gravity="bottom|end"
                            android:layout_margin="8dp"
                            android:background="#88000000"
                            android:padding="6dp"
                            android:src="@drawable/ic_mute"
                            android:clickable="true"
                            android:focusable="true"
                            android:stateListAnimator="@animator/focus_scale_button" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:background="#CC000000"
                            android:orientation="vertical"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="20dp"
                            android:paddingBottom="8dp">

                            <TextView
                                android:id="@+id/mini_channel_name"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_primary"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:maxLines="1"
                                android:ellipsize="end" />

                            <TextView
                                android:id="@+id/mini_epg_now"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textColor="@color/accent_warm"
                                android:textSize="10sp"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:visibility="gone" />

                            <LinearLayout
                                android:id="@+id/mini_epg_progress_track"
                                android:layout_width="match_parent"
                                android:layout_height="3dp"
                                android:layout_marginTop="4dp"
                                android:background="#40000000"
                                android:orientation="horizontal"
                                android:visibility="gone">

                                <View
                                    android:id="@+id/mini_epg_progress_fill"
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="0"
                                    android:background="@color/accent_purple" />

                                <View
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="100"
                                    android:background="@android:color/transparent" />
                            </LinearLayout>
                        </LinearLayout>
                    </FrameLayout>
                </LinearLayout>

                <!-- Vistos Reciente (antes "Continuar viendo"; mismo dato,
                     solo se renombró el título según el diseño nuevo) -->
                <LinearLayout
                    android:id="@+id/row_continue_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🕐  Vistos Reciente"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/btn_see_all_continue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:padding="4dp"
                            android:text="Ver todo ›"
                            android:textColor="@color/accent"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true"
                            android:stateListAnimator="@animator/focus_scale_row" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/row_continue"
                        android:descendantFocusability="afterDescendants"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        android:layout_marginBottom="22dp" />
                </LinearLayout>

                <!-- Última reproducción: card grande con miniatura + barra
                     de progreso + botón continuar, para el ítem visto MÁS
                     reciente (el primero de la misma lista de arriba). -->
                <LinearLayout
                    android:id="@+id/continue_hero_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:layout_marginBottom="22dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/continue_hero_card"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_card_rounded"
                        android:padding="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:stateListAnimator="@animator/focus_scale_card">

                        <ImageView
                            android:id="@+id/continue_hero_thumb"
                            android:layout_width="110dp"
                            android:layout_height="65dp"
                            android:scaleType="centerCrop"
                            android:background="@drawable/bg_card_rounded" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="14dp"
                            android:orientation="vertical"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="▶  Última reproducción"
                                android:textColor="@color/accent"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="6dp" />

                            <TextView
                                android:id="@+id/continue_hero_title"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:maxLines="1"
                                android:ellipsize="end" />

                            <TextView
                                android:id="@+id/continue_hero_sub"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="1dp"
                                android:textColor="@color/text_secondary"
                                android:textSize="10sp"
                                android:maxLines="1"
                                android:ellipsize="end" />

                            <LinearLayout
                                android:id="@+id/continue_hero_progress_track"
                                android:layout_width="match_parent"
                                android:layout_height="4dp"
                                android:layout_marginTop="8dp"
                                android:background="#2A2A3A"
                                android:orientation="horizontal">

                                <View
                                    android:id="@+id/continue_hero_progress_fill"
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="0"
                                    android:background="@drawable/bg_chip_active" />

                                <View
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="100"
                                    android:background="@android:color/transparent" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Favoritos -->
                <LinearLayout
                    android:id="@+id/row_favorites_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="♡  Favoritos"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/btn_see_all_favorites"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:padding="4dp"
                            android:text="Ver todo ›"
                            android:textColor="@color/accent"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true"
                            android:stateListAnimator="@animator/focus_scale_row" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/row_favorites"
                        android:descendantFocusability="afterDescendants"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        android:layout_marginBottom="22dp" />
                </LinearLayout>

                <!-- Accesos rápidos: como ya no hay filas de TV en vivo /
                     Películas / Series en el Home, estos 3 botones llevan
                     directo a esas pantallas completas. -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp">

                    <LinearLayout
                        android:id="@+id/quicknav_live"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_card_rounded"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:stateListAnimator="@animator/focus_scale_card">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📡"
                            android:textSize="18sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TV en vivo"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/quicknav_movies"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_card_rounded"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:stateListAnimator="@animator/focus_scale_card">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎬"
                            android:textSize="18sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Películas"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/quicknav_series"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_card_rounded"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:stateListAnimator="@animator/focus_scale_card">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📺"
                            android:textSize="18sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Series"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- ======================= PANEL LATERAL (DRAWER) ======================= -->
    <!-- Implementado a mano con un FrameLayout + traslación (sin agregar
         dependencias nuevas al proyecto). HomeActivity controla abrir/
         cerrar animando translationX del panel y la opacidad del scrim. -->
    <View
        android:id="@+id/drawer_scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#AA000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true" />

    <LinearLayout
        android:id="@+id/drawer_panel"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="@color/bg_secondary"
        android:fitsSystemWindows="true"
        android:visibility="gone"
        android:translationX="-280dp"
        android:paddingTop="22dp"
        android:paddingBottom="22dp"
        android:elevation="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginBottom="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="J"
                android:textColor="@color/accent"
                android:textSize="19sp"
                android:textStyle="bold|italic" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OX3"
                android:textColor="#2979FF"
                android:textSize="19sp"
                android:textStyle="bold|italic" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" TV"
                android:textColor="@color/accent_purple"
                android:textSize="19sp"
                android:textStyle="bold|italic" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="8dp"
            android:text="MENÚ"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <TextView
            android:id="@+id/drawer_item_home"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
