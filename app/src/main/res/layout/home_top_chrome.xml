<?xml version="1.0" encoding="utf-8"?>
<!--
    Header (hamburguesa+logo+buscar+ajustes), estado de cuenta, barra de
    búsqueda expandible, y los estados de carga/vacío. Igual en vertical
    y horizontal — compartido vía <include> para no duplicarlo.
-->
<merge xmlns:android="http://schemas.android.com/apk/res/android">

        <!-- Barra superior: hamburguesa + logo. Las pestañas Inicio/Canales/
             Películas/Series que estaban aquí se quitaron: ahora viven en
             el panel lateral (drawer) y como accesos rápidos al fondo del
             Home. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="18dp"
            android:paddingBottom="14dp">

            <ImageView
                android:id="@+id/btn_open_drawer"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_chip_inactive"
                android:padding="10dp"
                android:src="@drawable/ic_menu"
                android:clickable="true"
                android:focusable="true"
                android:stateListAnimator="@animator/focus_scale_button"
                android:layout_marginEnd="12dp" />

            <!-- Logo en 3 tramos de color para imitar el degradado
                 cian -> azul -> morado (un TextView solo no puede pintar
                 un degradado real en el texto sin un shader personalizado,
                 así que se simula con 3 colores planos consecutivos). -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="J"
                    android:textColor="@color/accent"
                    android:textSize="22sp"
                    android:textStyle="bold|italic" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OX3"
                    android:textColor="#2979FF"
                    android:textSize="22sp"
                    android:textStyle="bold|italic" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" TV"
                    android:textColor="@color/accent_purple"
                    android:textSize="22sp"
                    android:textStyle="bold|italic" />
            </LinearLayout>

            <!-- Botón de búsqueda global directo en el header: acceso
                 rápido sin necesidad de abrir el panel lateral primero.
                 Muestra/oculta la misma barra de búsqueda que ya existe
                 dentro del drawer (comparten el mismo inputSearch). -->
            <ImageView
                android:id="@+id/btn_search_header"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip_inactive"
                android:padding="10dp"
                android:src="@drawable/ic_search"
                android:tint="@color/accent"
                android:clickable="true"
                android:focusable="true"
                android:stateListAnimator="@animator/focus_scale_button" />

            <!-- Acceso directo a Ajustes sin tener que abrir el panel
                 lateral. "Ajustes" sigue existiendo también dentro del
                 drawer; este es solo un atajo rápido. -->
            <ImageView
                android:id="@+id/btn_settings"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_chip_inactive"
                android:padding="9dp"
                android:src="@drawable/ic_settings"
                android:tint="@color/accent"
                android:clickable="true"
                android:focusable="true"
                android:stateListAnimator="@animator/focus_scale_button" />
        </LinearLayout>

        <!-- Estado de cuenta: muy discreto a propósito (texto chico, color
             secundario, sin caja ni fondo) — solo un dato de referencia
             rápida, no debe competir visualmente con el resto del Home. -->
        <TextView
            android:id="@+id/account_status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingBottom="10dp"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:visibility="gone" />

        <!-- Barra de búsqueda expandible, oculta por defecto (se abre desde
             "Buscar" en el panel lateral) -->
        <LinearLayout
            android:id="@+id/search_bar_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingBottom="14dp"
            android:visibility="gone">

            <EditText
                android:id="@+id/input_search"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_chip_inactive"
                android:drawableStart="@drawable/ic_search"
                android:drawablePadding="10dp"
                android:hint="Buscar en vistos recientes o favoritos..."
                android:textColorHint="@color/text_secondary"
                android:textColor="@color/text_primary"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textSize="14sp"
                android:singleLine="true"
                android:imeOptions="actionSearch" />
        </LinearLayout>

        <!-- Pantalla de carga: visible mientras se descarga el catálogo
             por primera vez (autoLoadActiveAccount en HomeActivity).
             Antes esos segundos se veían en blanco/negro sin ningún
             indicador. -->
        <LinearLayout
            android:id="@+id/layout_loading"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <FrameLayout
                android:layout_width="86dp"
                android:layout_height="86dp"
                android:layout_marginBottom="20dp">

                <ProgressBar
                    android:id="@+id/loading_spinner"
                    style="?android:attr/progressBarStyleLarge"
                    android:layout_width="86dp"
                    android:layout_height="86dp"
                    android:indeterminateTint="@color/accent" />

                <TextView
                    android:id="@+id/loading_emoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="📡"
                    android:textSize="28sp" />
            </FrameLayout>

            <TextView
                android:id="@+id/loading_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cargando tu lista..."
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Esto puede tardar unos segundos"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Estado vacío (sin lista cargada) -->
        <LinearLayout
            android:id="@+id/layout_empty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Todavía no tienes una lista cargada"
                android:textColor="@color/text_secondary"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/btn_go_settings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_chip_active"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:text="Ir a Ajustes"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />
        </LinearLayout>

</merge>
