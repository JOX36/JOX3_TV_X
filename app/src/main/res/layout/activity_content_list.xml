<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <!-- Barra superior. El boton atras y el contador total ahora llevan
         el mismo estilo de marca que el resto de la app (boton con zoom,
         color cian, fondo redondeado). -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="18dp"
        android:paddingBottom="12dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/bg_chip_inactive"
            android:padding="9dp"
            android:src="@drawable/ic_back"
            android:tint="@color/accent"
            android:clickable="true"
            android:focusable="true"
            android:stateListAnimator="@animator/focus_scale_button" />

        <TextView
            android:id="@+id/tv_screen_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_total_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_pill_outline_accent"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:textColor="@color/accent"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Botón de categorías (compacto) + lupa. Ambos pasan de fondo plano
         gris a contorno de color de marca, igual al resto de chips de la
         app. -->
    <LinearLayout
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="14dp">

        <TextView
            android:id="@+id/btn_category_toggle"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_pill_outline_accent"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="Categorías  ▾"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:clickable="true"
            android:focusable="true"
            android:stateListAnimator="@animator/focus_scale_button" />

        <ImageView
            android:id="@+id/btn_search_toggle"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/bg_chip_inactive"
            android:padding="9dp"
            android:src="@drawable/ic_search"
            android:tint="@color/accent"
            android:clickable="true"
            android:focusable="true"
            android:stateListAnimator="@animator/focus_scale_button" />
    </LinearLayout>

    <!-- Lista vertical de categorías, oculta por defecto -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/category_dropdown_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="14dp"
        android:background="@drawable/bg_chip_inactive_transparent40"
        android:orientation="vertical"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:visibility="gone" />

    <!-- Buscador expandible, oculto por defecto -->
    <LinearLayout
        android:id="@+id/search_bar_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="14dp"
        android:visibility="gone">

        <EditText
            android:id="@+id/input_search"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_chip_inactive"
            android:drawableStart="@drawable/ic_search"
            android:drawablePadding="10dp"
            android:hint="Buscar en esta sección..."
            android:textColorHint="@color/text_secondary"
            android:textColor="@color/text_primary"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="14sp"
            android:singleLine="true"
            android:imeOptions="actionSearch" />
    </LinearLayout>

    <!-- Estado vacío -->
    <LinearLayout
        android:id="@+id/layout_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔍"
            android:textSize="40sp"
            android:layout_marginBottom="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No hay resultados"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- Secciones por categoría -->
    <ScrollView
        android:id="@+id/scroll_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/sections_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:paddingBottom="24dp" />
    </ScrollView>

</LinearLayout>
