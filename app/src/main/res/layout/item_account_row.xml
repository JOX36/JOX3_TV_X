<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_card_rounded"
    android:padding="14dp"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true"
    android:transformPivotX="0dp"
    android:stateListAnimator="@animator/focus_scale_row">

    <View
        android:id="@+id/account_active_dot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="@drawable/bg_chip_active"
        android:layout_marginEnd="12dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/account_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/account_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <TextView
        android:id="@+id/account_delete_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:text="Eliminar"
        android:textColor="#FF7A6E"
        android:textSize="11sp"
        android:textAllCaps="false"
        android:clickable="true"
        android:focusable="true"
        android:foreground="@drawable/bg_focus_overlay" />

</LinearLayout>
