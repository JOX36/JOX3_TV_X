<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        app:surface_type="texture_view" />

    <!-- Panel lateral: parrilla de canales de la categoría actual -->
    <LinearLayout
        android:id="@+id/channel_panel"
        android:layout_width="290dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#CC0D0D11"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/channel_panel_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="10dp"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/channel_panel_category_toggle"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_chip_inactive"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="Categorías  ▾"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:singleLine="true"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/bg_focus_overlay" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/channel_panel_category_dropdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_card_rounded"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/channel_panel_recycler"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />
    </LinearLayout>

    <!-- Indicador de gesto (volumen/brillo) -->
    <LinearLayout
        android:id="@+id/gesture_indicator"
        android:layout_width="140dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="#CC000000"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/gesture_icon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:tint="@color/text_primary" />

        <ProgressBar
            android:id="@+id/gesture_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="10dp"
            android:max="100" />

        <TextView
            android:id="@+id/gesture_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Panel "Siguiente episodio" -->
    <LinearLayout
        android:id="@+id/next_episode_panel"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:background="@color/bg_card"
        android:orientation="vertical"
        android:padding="14dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_next_episode_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_play_next"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:backgroundTint="@color/accent"
                android:text="Reproducir"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:foreground="@drawable/bg_focus_overlay" />

            <Button
                android:id="@+id/btn_skip_next"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:backgroundTint="@color/bg_secondary"
                android:text="Omitir"
                android:textAllCaps="false"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:foreground="@drawable/bg_focus_overlay" />
        </LinearLayout>
    </LinearLayout>

    <!-- Overlay de bloqueo de pantalla -->
    <FrameLayout
        android:id="@+id/lock_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/btn_unlock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="#CC000000"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="16dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/bg_focus_overlay"
            android:visibility="gone">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_lock"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Toca para desbloquear"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />
        </LinearLayout>
    </FrameLayout>

    <!-- Barra superior -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="#CC000000"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:padding="2dp"
            android:src="@drawable/ic_back"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/bg_focus_overlay" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_epg_now"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/accent_warm"
                android:textSize="11sp"
                android:singleLine="true"
                android:ellipsize="end"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/tv_epg_progress_track"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_marginTop="3dp"
                android:background="#40000000"
                android:orientation="horizontal"
                android:visibility="gone">

                <View
                    android:id="@+id/tv_epg_progress_fill"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0"
                    android:background="@color/accent_purple" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="100"
                    android:background="@android:color/transparent" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_resolution"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:textColor="@color/live_badge"
            android:textSize="12sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btn_fav"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/ic_star_outline"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/bg_focus_overlay" />
    </LinearLayout>

    <!-- Barra inferior -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#CC000000"
        android:orientation="vertical"
        android:padding="14dp"
        android:visibility="gone">

        <!-- Seek bar (solo VOD) -->
        <LinearLayout
            android:id="@+id/layout_seek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tv_position"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="@color/text_primary"
                android:textSize="11sp" />

            <SeekBar
                android:id="@+id/seek_bar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:max="100"
                android:progressTint="@color/accent"
                android:thumbTint="@color/accent" />

            <TextView
                android:id="@+id/tv_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="@color/text_primary"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Controles: fila principal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Botones específicos de EN VIVO -->
            <LinearLayout
                android:id="@+id/layout_live_btns"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:visibility="gone">

                <Button
                    android:id="@+id/btn_prev"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:minWidth="0dp"
                    android:padding="10dp"
                    android:text=""
                    android:drawableTop="@drawable/ic_skip_previous"
                    android:foreground="@drawable/bg_focus_overlay" />

                <Button
                    android:id="@+id/btn_pip_live"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:minWidth="0dp"
                    android:padding="10dp"
                    android:text=""
                    android:drawableTop="@drawable/ic_pip"
                    android:foreground="@drawable/bg_focus_overlay" />

                <Button
                    android:id="@+id/btn_stop"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:minWidth="0dp"
                    android:padding="10dp"
                    android:text=""
                    android:drawableTop="@drawable/ic_stop"
                    android:foreground="@drawable/bg_focus_overlay" />

                <Button
                    android:id="@+id/btn_next"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:minWidth="0dp"
                    android:padding="10dp"
                    android:text=""
                    android:drawableTop="@drawable/ic_skip_next"
                    android:foreground="@drawable/bg_focus_overlay" />

                <Button
                    android:id="@+id/btn_channel_list"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:minWidth="0dp"
                    android:padding="10dp"
                    android:text=""
                    android:drawableTop="@drawable/ic_channel_list"
                    android:foreground="@drawable/bg_focus_overlay" />

                <Button
                    android:id="@+id/btn_refresh"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:minWidth="0dp"
                    android:padding="10dp"
                    android:text=""
                    android:drawableTop="@drawable/ic_refresh"
                    android:foreground="@drawable/bg_focus_overlay" />
            </LinearLayout>

            <!-- Botones específicos de VOD -->
            <LinearLayout
                android:id="@+id/layout_vod_btns"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:visibility="gone">

                <Button
                    android:id="@+id/btn_prev_ep"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:minWidth="0dp"
                    android:padding="8dp"
                    android:text=""
                    android:drawableTop="@drawable/ic_skip_previous"
                    android:foreground="@drawable/bg_focus_overlay"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btn_rewind"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:minWidth="0dp"
                    android:padding="8dp"
                    android:text=""
                    android:drawableTop="@drawable/ic_rewind"
                    android:foreground="@drawable/bg_focus_overlay" />

                <FrameLayout
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_circle_accent" />

                    <Button
                        android:id="@+id/btn_play_pause"
                        style="?android:attr/borderlessButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:minWidth="0dp"
                        android:padding="14dp"
                        android:background="@android:color/transparent"
                        android:text=""
                        android:drawableTop="@drawable/ic_pause"
                        android:foreground="@drawable/bg_focus_overlay" />
                </FrameLayout>

                <Button
                    android:id="@+id/btn_forward"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:minWidth="0dp"
                    android:padding="8dp"
                    android:text=""
                    android:drawableTop="@drawable/ic_forward"
                    android:foreground="@drawable/bg_focus_overlay" />

                <Button
                    android:id="@+id/btn_next_ep"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:minWidth="0dp"
                    android:padding="8dp"
                    android:text=""
                    android:drawableTop="@drawable/ic_skip_next"
                    android:foreground="@drawable/bg_focus_overlay"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btn_audio"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:minWidth="0dp"
                    android:padding="8dp"
                    android:text=""
                    android:drawableTop="@drawable/ic_audio"
                    android:foreground="@drawable/bg_focus_overlay" />

                <Button
                    android:id="@+id/btn_subs"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:minWidth="0dp"
                    android:padding="8dp"
                    android:text=""
                    android:drawableTop="@drawable/ic_subtitles"
                    android:foreground="@drawable/bg_focus_overlay" />

                <Button
                    android:id="@+id/btn_speed"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:minWidth="0dp"
                    android:padding="8dp"
                    android:text="1x"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:foreground="@drawable/bg_focus_overlay" />

                <Button
                    android:id="@+id/btn_pip"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:minWidth="0dp"
                    android:padding="8dp"
                    android:text=""
                    android:drawableTop="@drawable/ic_pip"
                    android:foreground="@drawable/bg_focus_overlay" />

                <Button
                    android:id="@+id/btn_stop_vod"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:minWidth="0dp"
                    android:padding="8dp"
                    android:text=""
                    android:drawableTop="@drawable/ic_stop"
                    android:foreground="@drawable/bg_focus_overlay" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_lock"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:minWidth="0dp"
                android:padding="8dp"
                android:text=""
                android:drawableTop="@drawable/ic_lock_open"
                android:foreground="@drawable/bg_focus_overlay" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
