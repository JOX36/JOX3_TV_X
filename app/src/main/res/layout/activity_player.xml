<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000" />

    <!-- Indicador de gesto (volumen/brillo) -->
    <LinearLayout
        android:id="@+id/gesture_indicator"
        android:layout_width="140dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="#CC000000"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/gesture_icon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:tint="@color/text_primary" />

        <ProgressBar
            android:id="@+id/gesture_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="10dp"
            android:max="100" />

        <TextView
            android:id="@+id/gesture_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Panel "Siguiente episodio" -->
    <LinearLayout
        android:id="@+id/next_episode_panel"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:background="@color/bg_card"
        android:orientation="vertical"
        android:padding="14dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_next_episode_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_play_next"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:backgroundTint="@color/accent"
                android:text="Reproducir"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_skip_next"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:backgroundTint="@color/bg_secondary"
                android:text="Omitir"
                android:textAllCaps="false"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Overlay de bloqueo de pantalla -->
    <FrameLayout
        android:id="@+id/lock_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <TextView
            android:id="@+id/btn_unlock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="#CC000000"
            android:padding="16dp"
            android:text="ðŸ”’ Toca para desbloquear"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Barra superior -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="#CC000000"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="â†"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tv_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_resolution"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:textColor="@color/live_badge"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_fav"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="â˜†"
            android:textColor="@color/favorite_yellow"
            android:textSize="20sp"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Barra inferior -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#CC000000"
        android:orientation="vertical"
        android:padding="14dp"
        android:visibility="gone">

        <!-- Seek bar (solo VOD) -->
        <LinearLayout
            android:id="@+id/layout_seek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tv_position"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="@color/text_primary"
                android:textSize="11sp" />

            <SeekBar
                android:id="@+id/seek_bar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:max="100"
                android:progressTint="@color/accent"
                android:thumbTint="@color/accent" />

            <TextView
                android:id="@+id/tv_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="@color/text_primary"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Controles: fila principal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Botones especÃ­ficos de EN VIVO -->
            <LinearLayout
                android:id="@+id/layout_live_btns"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:visibility="gone">

                <TextView
                    android:id="@+id/btn_prev"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="â®"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:padding="10dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btn_pip_live"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="â§‰"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:padding="10dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btn_stop"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="â¹"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:padding="10dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btn_next"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="â­"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:padding="10dp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Botones especÃ­ficos de VOD -->
            <LinearLayout
                android:id="@+id/layout_vod_btns"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:visibility="gone">

                <TextView
                    android:id="@+id/btn_prev_ep"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="â®"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/btn_rewind"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="âª"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btn_play_pause"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="â¸"
                    android:textColor="@color/text_primary"
                    android:textSize="26sp"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btn_forward"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="â©"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btn_next_ep"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="â­"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/btn_audio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ðŸ”Š"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btn_subs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ðŸ’¬"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btn_speed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1x"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btn_pip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="â§‰"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btn_stop_vod"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="â¹"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <TextView
                android:id="@+id/btn_lock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ðŸ”“"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
