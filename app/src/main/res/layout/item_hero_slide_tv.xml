<?xml version="1.0" encoding="utf-8"?>
<!-- Version TV box (con control remoto): mantiene sinopsis y botones Reproducir/Favorito visibles en la propia card del banner, ya que en TV no hay "tap" sino seleccion directa con el control. La version movil simplificada esta en item_hero_slide.xml. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/bg_card_rounded"
    android:clipToOutline="true">

    <ImageView
        android:id="@+id/hero_poster"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.42"
        android:scaleType="centerCrop" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.58"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:padding="22dp">

        <TextView
            android:id="@+id/hero_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_live"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:text="EN VIVO"
            android:textColor="@color/text_primary"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/hero_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/hero_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:textColor="@color/accent"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <TextView
            android:id="@+id/hero_synopsis"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:lineSpacingExtra="3dp"
            android:maxLines="4"
            android:ellipsize="end" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <TextView
                android:id="@+id/hero_btn_play"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_active"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:paddingTop="11dp"
                android:paddingBottom="11dp"
                android:text="Reproducir"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textAllCaps="false"
                android:maxLines="1"
                android:ellipsize="end"
                android:clickable="true"
                android:focusable="true"
                android:foreground="@drawable/bg_focus_overlay"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/hero_btn_fav"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_inactive"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="11dp"
                android:paddingBottom="11dp"
                android:text="Favorito"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textAllCaps="false"
                android:maxLines="1"
                android:ellipsize="end"
                android:clickable="true"
                android:focusable="true"
                android:foreground="@drawable/bg_focus_overlay" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
