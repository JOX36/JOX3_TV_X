<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fitsSystemWindows="true"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Cabecera -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_chip_active"
                android:padding="7dp"
                android:src="@drawable/ic_settings" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Ajustes"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Lista de cuentas guardadas -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tus cuentas"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_marginBottom="10dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/accounts_recycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />

        <TextView
            android:id="@+id/tv_no_accounts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Todavía no tienes ninguna cuenta guardada."
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:gravity="center"
            android:padding="20dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btn_toggle_add_account"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_chip_active"
            android:text="+  Agregar cuenta nueva"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:textSize="13sp" />

        <!-- Formulario para agregar cuenta (colapsable) -->
        <LinearLayout
            android:id="@+id/add_account_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_rounded"
            android:padding="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/bg_secondary"
                android:orientation="horizontal"
                android:padding="4dp"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/tab_xtream"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/accent"
                    android:text="Xtream Codes"
                    android:textColor="@color/text_primary"
                    android:textAllCaps="false"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/tab_m3u"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/bg_secondary"
                    android:text="Lista M3U"
                    android:textColor="@color/text_secondary"
                    android:textAllCaps="false"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/form_xtream"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <EditText
                    android:id="@+id/input_name_xtream"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_chip_inactive"
                    android:hint="Nombre (ej. Mi Lista Principal)"
                    android:textColorHint="@color/text_secondary"
                    android:textColor="@color/text_primary"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textSize="13sp"
                    android:inputType="text" />

                <EditText
                    android:id="@+id/input_server"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_chip_inactive"
                    android:hint="http://servidor.com:8080"
                    android:textColorHint="@color/text_secondary"
                    android:textColor="@color/text_primary"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textSize="13sp"
                    android:inputType="textUri" />

                <EditText
                    android:id="@+id/input_user"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_chip_inactive"
                    android:hint="Usuario"
                    android:textColorHint="@color/text_secondary"
                    android:textColor="@color/text_primary"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textSize="13sp"
                    android:inputType="text" />

                <EditText
                    android:id="@+id/input_pass"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/bg_chip_inactive"
                    android:hint="Contraseña"
                    android:textColorHint="@color/text_secondary"
                    android:textColor="@color/text_primary"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textSize="13sp"
                    android:inputType="textPassword" />

                <Button
                    android:id="@+id/btn_save_xtream"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:background="@drawable/bg_chip_active"
                    android:text="Conectar y guardar"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/form_m3u"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <EditText
                    android:id="@+id/input_name_m3u"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_chip_inactive"
                    android:hint="Nombre (ej. Mi Lista M3U)"
                    android:textColorHint="@color/text_secondary"
                    android:textColor="@color/text_primary"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textSize="13sp"
                    android:inputType="text" />

                <EditText
                    android:id="@+id/input_m3u_url"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/bg_chip_inactive"
                    android:hint="http://servidor.com/lista.m3u"
                    android:textColorHint="@color/text_secondary"
                    android:textColor="@color/text_primary"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textSize="13sp"
                    android:inputType="textUri" />

                <Button
                    android:id="@+id/btn_save_m3u"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:background="@drawable/bg_chip_active"
                    android:text="Cargar lista"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:textSize="13sp" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progress_loading"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_gravity="center"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Pie de versión -->
        <TextView
            android:id="@+id/tv_app_version"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:textSize="11sp" />

    </LinearLayout>
</ScrollView>
