<?xml version="1.0" encoding="utf-8"?>
<!--
    Filas de contenido del Home (Seguir viendo series, Continúa tus
    películas, Última reproducción, Favoritos, Descubre, Destacados).
    Extraído a un archivo aparte para que tanto el layout vertical como
    el horizontal (layout-land) usen EXACTAMENTE el mismo bloque vía
    <include>, sin duplicar 450 líneas de XML en dos archivos que se
    podrían desincronizar con el tiempo. NO incluye global_search_results
    a propósito: esa vive aparte en cada layout porque su posición en
    pantalla cambia entre vertical y horizontal.
-->
<merge xmlns:android="http://schemas.android.com/apk/res/android">

                <View android:id="@+id/divider_a" style="@null"
                    android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginBottom="18dp"
                    android:background="@drawable/bg_section_divider"
                    android:visibility="gone" />

                <!-- "Seguir viendo series": separado de "Vistos Reciente"
                     porque son cosas distintas (esta solo trae series con
                     episodio a medias, con su badge T{temporada} E{episodio}
                     usando los campos season/episode de MediaItem). -->
                <LinearLayout
                    android:id="@+id/row_continue_series_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="📺  Seguir viendo series"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/row_continue_series"
                        android:descendantFocusability="afterDescendants"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        android:layout_marginBottom="22dp" />
                </LinearLayout>

                <View android:id="@+id/divider_b" style="@null"
                    android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginBottom="18dp"
                    android:background="@drawable/bg_section_divider"
                    android:visibility="gone" />

                <!-- "Continúa tus películas" (antes "Vistos Reciente",
                     que era redundante con "Última reproducción" y
                     "Seguir viendo series"). Ahora solo trae películas con
                     avance, igual de specifico que la fila de series. -->
                <LinearLayout
                    android:id="@+id/row_continue_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🎬  Continúa tus películas"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/btn_see_all_continue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:padding="4dp"
                            android:text="Ver todo ›"
                            android:textColor="@color/accent"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true"
                            android:stateListAnimator="@animator/focus_scale_row" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/row_continue"
                        android:descendantFocusability="afterDescendants"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        android:layout_marginBottom="22dp" />
                </LinearLayout>

                <View android:id="@+id/divider_c"
                    android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginBottom="18dp"
                    android:background="@drawable/bg_section_divider"
                    android:visibility="gone" />

                <!-- Última reproducción: card grande, ahora con la imagen
                     del canal/poster DIFUMINADA de fondo (vidrio esmerilado)
                     y la info al frente. El difuminado real lo hace
                     BlurTransformation (jp.wasabeef:glide-transformations)
                     al cargar continue_hero_bg en HomeActivity.java. -->
                <LinearLayout
                    android:id="@+id/continue_hero_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:layout_marginBottom="22dp"
                    android:visibility="gone">

                    <FrameLayout
                        android:id="@+id/continue_hero_card"
                        android:layout_width="match_parent"
                        android:layout_height="172dp"
                        android:background="@drawable/bg_card_rounded"
                        android:clipToOutline="true"
                        android:clickable="true"
                        android:focusable="true"
                        android:stateListAnimator="@animator/focus_scale_card">

                        <!-- Fondo difuminado (la misma imagen del canal/
                             poster, pero borrosa). Si Glide todavía no
                             cargó nada, se ve el fondo oscuro normal de
                             bg_card_rounded por detrás. -->
                        <ImageView
                            android:id="@+id/continue_hero_bg"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop" />

                        <!-- Oscurecido encima del difuminado, para que el
                             texto siempre se lea sin importar qué tan
                             clara sea la imagen de fondo. -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_gradient_glass_overlay" />

                        <TextView
                            android:id="@+id/continue_hero_live_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="top|end"
                            android:layout_margin="12dp"
                            android:background="@drawable/bg_badge_live"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp"
                            android:text="EN VIVO"
                            android:textColor="@color/text_primary"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:visibility="gone" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="16dp">

                            <ImageView
                                android:id="@+id/continue_hero_thumb"
                                android:layout_width="80dp"
                                android:layout_height="80dp"
                                android:scaleType="centerCrop"
                                android:background="@drawable/bg_card_rounded" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="14dp"
                                android:orientation="vertical"
                                android:gravity="center_vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="▶  ÚLTIMA REPRODUCCIÓN"
                                    android:textColor="@color/accent"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:letterSpacing="0.03"
                                    android:layout_marginBottom="6dp" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <TextView
                                        android:id="@+id/continue_hero_title"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:textColor="@color/text_primary"
                                        android:textSize="15sp"
                                        android:textStyle="bold"
                                        android:maxLines="1"
                                        android:ellipsize="end" />

                                    <TextView
                                        android:id="@+id/continue_hero_quality"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:background="#88000000"
                                        android:paddingStart="6dp"
                                        android:paddingEnd="6dp"
                                        android:paddingTop="2dp"
                                        android:paddingBottom="2dp"
                                        android:text="HD"
                                        android:textColor="@color/text_primary"
                                        android:textSize="9sp"
                                        android:textStyle="bold"
                                        android:visibility="gone" />
                                </LinearLayout>

                                <TextView
                                    android:id="@+id/continue_hero_sub"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="11sp"
                                    android:maxLines="1"
                                    android:ellipsize="end" />

                                <LinearLayout
                                    android:id="@+id/continue_hero_progress_track"
                                    android:layout_width="match_parent"
                                    android:layout_height="4dp"
                                    android:layout_marginTop="9dp"
                                    android:background="#40FFFFFF"
                                    android:orientation="horizontal">

                                    <View
                                        android:id="@+id/continue_hero_progress_fill"
                                        android:layout_width="0dp"
                                        android:layout_height="match_parent"
                                        android:layout_weight="0"
                                        android:background="@drawable/bg_chip_active" />

                                    <View
                                        android:layout_width="0dp"
                                        android:layout_height="match_parent"
                                        android:layout_weight="100"
                                        android:background="@android:color/transparent" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </FrameLayout>
                </LinearLayout>

                <View android:id="@+id/divider_d"
                    android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginBottom="18dp"
                    android:background="@drawable/bg_section_divider"
                    android:visibility="gone" />

                <!-- Favoritos -->
                <LinearLayout
                    android:id="@+id/row_favorites_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="♡  Favoritos"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/btn_see_all_favorites"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:padding="4dp"
                            android:text="Ver todo ›"
                            android:textColor="@color/accent"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true"
                            android:stateListAnimator="@animator/focus_scale_row" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/row_favorites"
                        android:descendantFocusability="afterDescendants"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        android:layout_marginBottom="22dp" />
                </LinearLayout>

                <View android:id="@+id/divider_e"
                    android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginBottom="18dp"
                    android:background="@drawable/bg_section_divider"
                    android:visibility="gone" />

                <!-- "Descubre algo nuevo": random de lo que NO está en
                     Vistos Reciente, con botón 🔀 para regenerar la
                     selección sin recargar toda la lista de la cuenta. -->
                <LinearLayout
                    android:id="@+id/row_discover_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🔀  Descubre algo nuevo"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/btn_shuffle_discover"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:padding="6dp"
                            android:text="🔀"
                            android:textSize="16sp"
                            android:clickable="true"
                            android:focusable="true"
                            android:stateListAnimator="@animator/focus_scale_button" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/row_discover"
                        android:descendantFocusability="afterDescendants"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        android:layout_marginBottom="22dp" />
                </LinearLayout>

                <View android:id="@+id/divider_f"
                    android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginBottom="18dp"
                    android:background="@drawable/bg_section_divider"
                    android:visibility="gone" />

                <!-- Fila fija de UNA categoría destacada (la de más ítems
                     en tu catálogo de películas/series). El título se
                     llena dinámicamente con el nombre real de esa
                     categoría, no es un texto fijo en el XML. -->
                <LinearLayout
                    android:id="@+id/row_featured_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:id="@+id/tv_featured_title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="⭐  Destacados"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/row_featured"
                        android:descendantFocusability="afterDescendants"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        android:layout_marginBottom="22dp" />
                </LinearLayout>

</merge>
