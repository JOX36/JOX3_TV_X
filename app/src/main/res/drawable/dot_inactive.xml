<?xml version="1.0" encoding="utf-8"?>
<!--
    El contenedor (View) mide 7dp de alto, pero el punto visible solo
    ocupa el centro (2dp arriba y abajo quedan vacíos/transparentes) para
    dejar espacio al halo del punto activo sin que los puntos "salten" de
    tamaño al cambiar de página.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:top="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#33334A" />
            <corners android:radius="2dp" />
        </shape>
    </item>
</layer-list>
