<?xml version="1.0" encoding="utf-8"?>
<!--
    Reemplaza el fondo plano #CC000000 (80% opaco) de la barra superior
    del reproductor. Ahora es un degradado que va oscuro arriba (para que
    el título/botones se lean) y se desvanece a transparente hacia abajo,
    dejando ver mucho más el video detrás — pedido de JOX3 tras ver las
    barras muy sólidas en la captura.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <gradient
        android:angle="270"
        android:startColor="#8C000000"
        android:endColor="#00000000" />
</shape>
