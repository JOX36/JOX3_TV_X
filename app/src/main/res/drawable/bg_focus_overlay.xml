<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Solo se ve cuando el control remoto/D-pad selecciona este elemento.
         En celular (modo táctil) Android nunca activa state_focused así,
         por lo que esto es invisible al tocar con el dedo. -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <stroke android:width="3dp" android:color="#FF5722" />
            <corners android:radius="10dp" />
            <solid android:color="#33FF5722" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</selector>
