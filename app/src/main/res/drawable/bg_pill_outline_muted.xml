<?xml version="1.0" encoding="utf-8"?>
<!--
    Botón "secundario" de los diálogos de marca (ej. "Cancelar",
    "Desde el inicio"): outline gris neutro, para que no compita
    visualmente con el botón principal que sí lleva el gradiente de
    marca.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <solid android:color="@android:color/transparent" />
    <stroke android:width="1dp" android:color="#3A3A50" />
    <corners android:radius="12dp" />
</shape>
